{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/schemas/validate_module_definition.response.schema.json",
  "title": "validate-module-definition result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "valid",
    "normalized_module"
  ],
  "properties": {
    "valid": {
      "type": "boolean",
      "const": true
    },
    "normalized_module": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "capabilities",
        "entrypoint"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "runtime",
            "compiler",
            "tooling"
          ]
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "entrypoint": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "module",
            "callable"
          ],
          "properties": {
            "module": {
              "type": "string",
              "minLength": 1
            },
            "callable": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
