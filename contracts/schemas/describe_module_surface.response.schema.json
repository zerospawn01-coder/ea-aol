{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/schemas/describe_module_surface.response.schema.json",
  "title": "describe-module-surface result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "module_surface"
  ],
  "properties": {
    "module_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "module_key",
        "kind",
        "name",
        "entrypoint_ref",
        "capability_count",
        "capability_surface",
        "ready_for_runtime_registration"
      ],
      "properties": {
        "module_key": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "runtime",
            "compiler",
            "tooling"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "entrypoint_ref": {
          "type": "string",
          "minLength": 1
        },
        "capability_count": {
          "type": "number"
        },
        "capability_surface": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "ready_for_runtime_registration": {
          "type": "boolean"
        }
      }
    }
  }
}
