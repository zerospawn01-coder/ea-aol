{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/schemas/response_envelope.schema.json",
  "title": "EA-AOL Response Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "operation",
    "contract_version"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "error"
      ]
    },
    "operation": {
      "type": "string",
      "minLength": 1
    },
    "contract_version": {
      "const": "ea-aol/0.1"
    },
    "result": {
      "type": "object"
    },
    "error": {
      "type": "object"
    }
  }
}
